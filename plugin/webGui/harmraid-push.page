Menu="Utilities"
Icon="/plugins/harmraid-push/icon.png"
Title="Harmraid-Push"
---
<?php
$configDir = '/boot/config/plugins/harmraid-push';
$pushEnabled = trim(@file_get_contents("$configDir/push_enabled.txt")) ?: 'false';
$pushTypes = trim(@file_get_contents("$configDir/types.txt")) ?: 'alert,warning,info';
$tokenLines = array_filter(file("$configDir/push_token.txt", FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) ?: []);
$latestToken = end($tokenLines) ?: '';
$tokenDisplay = $latestToken ? substr($latestToken, 0, 16) . '...' : '未注册';
$deviceCount = count($tokenLines);

if ($_GET['action'] === 'register') {
  $t = $_GET['token'] ?? '';
  $saRaw = $_GET['service_account'] ?? '';
  if ($t) {
    file_put_contents("$configDir/push_token.txt", $t . "\n", FILE_APPEND | LOCK_EX);
    if ($saRaw) {
      $saDecoded = urldecode($saRaw);
      file_put_contents("$configDir/service-account.json", $saDecoded);
    }
    echo '{"status":"ok"}';
  } else {
    echo '{"status":"error","message":"Missing token"}';
  }
  exit;
}

if ($_GET['action'] === 'save') {
  if (!is_dir($configDir)) {
    mkdir($configDir, 0755, true);
  }

  $pushEnabled = isset($_GET['push_enabled']) && $_GET['push_enabled'] === 'true' ? 'true' : 'false';
  file_put_contents("$configDir/push_enabled.txt", $pushEnabled);

  $types = [];
  foreach (['alert', 'warning', 'info'] as $t) {
    if (isset($_GET['type_' . $t]) && $_GET['type_' . $t] === $t) {
      $types[] = $t;
    }
  }
  $pushTypes = implode(',', $types);
  file_put_contents("$configDir/types.txt", $pushTypes);

  $readBack = trim(@file_get_contents("$configDir/push_enabled.txt")) ?: '';
  $saved = ($readBack === $pushEnabled);

  $pushEnabled = $readBack ?: 'false';
  $pushTypes = trim(@file_get_contents("$configDir/types.txt")) ?: 'alert,warning,info';
}

if ($_GET['format'] === 'json') {
  header('Content-Type: application/json');
  echo json_encode([
    'installed' => true,
    'version' => '1.0.4',
    'pushEnabled' => $pushEnabled === 'true',
    'pushTypes' => $pushTypes,
    'hasCredentials' => $deviceCount > 0,
    'configStatus' => 'configured',
    'deviceCount' => $deviceCount
  ]);
  exit;
}
?>
<link rel="stylesheet" href="/webGui/styles/default.css">
<div style="display:flex;align-items:center;justify-content:space-between;">
  <h1>Harmraid-Push <a href="https://github.com/shanyan-wcx/Harmraid-Push" target="_blank" style="background:#24292e;color:white;padding:2px 8px;border-radius:4px;text-decoration:none;font-size:11px;vertical-align:middle;margin-left:8px;">GitHub</a></h1>
</div>
<p>Harmraid 应用的 Unraid 推送通知插件。</p>
<hr>
<form method="GET">
<input type="hidden" name="action" value="save">
<h3>推送状态</h3>
<label><input type="checkbox" name="push_enabled" value="true" <?=$pushEnabled === 'true' ? 'checked' : ''?>> 启用推送通知</label><br><br>
<h3>通知类型</h3>
<?php foreach (['alert' => '错误 (Alert)', 'warning' => '警告 (Warning)', 'info' => '普通通知 (Info)'] as $k => $v): ?>
<input type="hidden" name="type_<?=$k?>" value="">
<label><input type="checkbox" name="type_<?=$k?>" value="<?=$k?>" <?=strpos($pushTypes, $k) !== false ? 'checked' : ''?>> <?=$v?></label><br>
<?php endforeach; ?><br>
<h3>设备状态</h3>
<p>已注册设备: <?=$deviceCount?> 台</p>
<p>最新推送令牌: <?=$tokenDisplay?></p><br>
<input type="submit" value="保存设置" class="button">
<?php if (isset($saved) && $saved): ?>
<p style="color:#27ae60;margin-top:8px;">✅ 已保存</p>
<?php endif; ?>
</form>
