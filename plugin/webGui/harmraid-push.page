  <th style="padding:8px 4px;text-align:left;font-size:12px;color:#888;font-weight:600;">设备名称</th>
  <th style="padding:8px 4px;text-align:left;font-size:12px;color:#888;font-weight:600;">推送令牌</th>
  <th style="padding:8px 4px;width:50px;"></th>
</tr>
<?php $idx = 0; foreach ($devices as $d): ?>
<tr style="border-bottom:1px solid #eee;">
  <td style="padding:6px 4px;font-size:13px;"><?=htmlspecialchars($d['device_name'])?></td>
  <td style="padding:6px 4px;white-space:nowrap;">
    <span class="token-wrap" data-token="<?=htmlspecialchars($d['token'])?>" data-prefix="<?=htmlspecialchars(substr($d['token'],0,8))?>"
          style="font-size:11px;color:#666;font-family:monospace;">
      <?=htmlspecialchars(substr($d['token'],0,8))?>
    </span>
    <button onclick="toggleToken(this)" style="background:none;border:none;cursor:pointer;font-size:14px;vertical-align:middle;">👁️‍🗨️</button>
  </td>
  <td style="padding:6px 4px;">
    <form method="GET" style="display:inline;">
    <input type="hidden" name="cmd" value="save">
    <input type="hidden" name="delete_idx" value="<?=$idx?>">
    <button type="submit" style="background:none;border:none;color:#c00;cursor:pointer;font-size:12px;padding:0;" onclick="return confirm('确认删除此设备？')">删除</button>
    </form>
  </td>
</tr>
<?php $idx++; endforeach; ?>
</table>
<script>
function toggleToken(btn) {
  var wrap = btn.parentElement.querySelector('.token-wrap');
  var full = wrap.dataset.token || '';
  var prefix = wrap.dataset.prefix || '';
  if (!full) return;
  if (wrap.textContent === full) {
    wrap.textContent = prefix;
    btn.textContent = '\u{1F441}\u{FE0F}\u{200D}\u{1F5E8}\u{FE0F}';
  } else {
    wrap.textContent = full;
    btn.textContent = '\u{1F441}';
  }
}
</script>
<?php else: ?>
<p style="color:#888;margin-top:4px;">无推送令牌</p>
<?php endif; ?>

<hr>

<h3>发送测试通知</h3>
<button onclick="sendTestPush()" style="background:#27ae60;color:white;border:none;padding:8px 16px;border-radius:6px;cursor:pointer;font-size:14px;">📤 发送测试通知</button>
<div id="push-log" style="margin-top:10px;max-height:200px;overflow:auto;font-size:11px;background:#1e1e1e;color:#d4d4d4;padding:10px;border-radius:6px;font-family:monospace;display:none;"></div>
<script>
function sendTestPush() {
  var log = document.getElementById('push-log');
  log.style.display = 'block';
  log.textContent = '发送中...\n';
  var xhr = new XMLHttpRequest();
  xhr.open('GET', '?cmd=test_push');
  xhr.onload = function() {
    if (xhr.status === 200) {
      log.textContent = xhr.responseText;
    } else {
      log.textContent = '请求失败 (HTTP ' + xhr.status + ')\n';
    }
  };
  xhr.onerror = function() {
    log.textContent = '网络错误\n';
  };
  xhr.send();
}
</script>
