<?php
$logFile = "$configDir/add_device.log";
if (file_exists($logFile)) {
  $log = json_decode(file_get_contents($logFile), true);
  echo '<p style="font-size:12px;color:#888;">退出码: ' . $log['code'] . ' | 时间: ' . date('H:i:s', $log['time']) . '</p>';
  $resultMsg = '';
  if (!empty($log['output'])) {
    foreach ($log['output'] as $l) {
      if (preg_match('/"80000000"/', $l)) {
        $resultMsg = '✅ 推送成功';
      } elseif (preg_match('/"(\d+)"/', $l, $m)) {
        $resultMsg = '❌ 发送失败（错误码: ' . $m[1] . '）';
      }
    }
  }
  echo '<pre style="margin-top:10px;max-height:200px;overflow:auto;font-size:11px;background:#1e1e1e;color:#d4d4d4;padding:10px;border-radius:6px;border:1px solid #333;font-family:monospace;">';
  echo $resultMsg ? htmlspecialchars($resultMsg) : '无输出';
  echo '</pre>';
} else {
  echo '<p style="color:#888;font-size:12px;">暂无设备添加记录</p>';
}
?>

<script>
function apiCall(cmd, extra, cb) {
  var url = '/plugins/harmraid-push/api.php?cmd=' + cmd + '&' + extra;
  var xhr = new XMLHttpRequest();
  xhr.open('GET', url);
  xhr.onload = function() {
    if (xhr.status === 200) { if (cb) cb(xhr.responseText); }
  };
  xhr.send();
}

function saveTypes() {
  var extra = '';
  <?php foreach (['ALERT','WARNING','INFO'] as $k): ?>
  extra += 'type_<?=$k?>=' + (document.getElementById('cb_<?=$k?>').checked ? '<?=$k?>' : '') + '&';
  <?php endforeach; ?>
  apiCall('save_types', extra, function(){
    document.getElementById('save-msg').style.display = 'block';
    setTimeout(function(){ location.reload(); }, 1500);
  });
}

function addDevice() {
  var token = document.getElementById('push_token').value.trim();
  if (!token) { alert('请输入推送令牌'); return; }
  var name = encodeURIComponent(document.getElementById('device_name').value.trim());
  apiCall('add_device', 'push_token=' + encodeURIComponent(token) + '&device_name=' + name, function(){ location.reload(); });
}

function deleteDevice(idx) {
  if (!confirm('确认删除此设备？')) return;
  apiCall('delete_idx', 'idx=' + idx, function(){ location.reload(); });
}

function toggleToken(btn) {
  var wrap = btn.parentElement.querySelector('.token-wrap');
  var full = wrap.dataset.token || '';
  var prefix = wrap.dataset.prefix || '';
  if (!full) return;
  if (wrap.textContent === full) {
    wrap.textContent = prefix;
    btn.textContent = '\u{1F441}\u{FE0F}\u{200D}\u{1F5E8}\u{FE0F}';
  } else {
    wrap.textContent = full;
    btn.textContent = '\u{1F441}';
  }
}

function sendTestPush() {
  var log = document.getElementById('push-log');
  log.style.display = 'block';
  log.textContent = '发送中...\n';
  var xhr = new XMLHttpRequest();
  xhr.open('GET', '/plugins/harmraid-push/api.php?cmd=test_push');
  xhr.onload = function() {
    log.textContent = xhr.status === 200 ? xhr.responseText : '请求失败 (HTTP ' + xhr.status + ')\n';
  };
  xhr.onerror = function() { log.textContent = '网络错误\n'; };
  xhr.send();
}
</script>
