<?xml version="1.0"?>
<!DOCTYPE PLUGIN [
<!ENTITY name      "harmraid-push">
<!ENTITY author    "shanyan-wcx">
<!ENTITY version   "1.0.5">
<!ENTITY pluginURL "https://raw.githubusercontent.com/shanyan-wcx/Harmraid-Push/main/plugin/&name;.plg">
<!ENTITY github    "https://github.com/shanyan-wcx/Harmraid-Push">
]>
<PLUGIN name="Harmraid-Push" author="&author;" version="&version;" launch="Utilities/Harmraid-Push" pluginURL="&pluginURL;" github="&github;" supportURL="&github;" support="https://github.com/shanyan-wcx/Harmraid-Push" description="Harmraid 应用的 Unraid 推送通知插件。">
  <CHANGES>
  </CHANGES>
  <ICON>https://raw.githubusercontent.com/shanyan-wcx/Harmraid-Push/main/plugin/icon.png</ICON>
  <FILE Run="/bin/bash">
    <INLINE>
set -e
rm -rf /usr/local/emhttp/plugins/harmraid-push
    </INLINE>
  </FILE>
  <FILE Name="/usr/local/emhttp/plugins/harmraid-push/icon.png">
    <URL>https://raw.githubusercontent.com/shanyan-wcx/Harmraid-Push/main/plugin/icon.png</URL>
  </FILE>
  <FILE Name="/boot/config/plugins/harmraid-push/service-account.json.enc">
    <URL>https://raw.githubusercontent.com/shanyan-wcx/Harmraid-Push/main/plugin/service-account.json.enc</URL>
    <RUN mode="600">chmod 600 /boot/config/plugins/harmraid-push/service-account.json.enc</RUN>
  </FILE>
  <FILE Name="/usr/local/emhttp/plugins/harmraid-push/send-push.sh">
    <URL>https://raw.githubusercontent.com/shanyan-wcx/Harmraid-Push/main/plugin/send-push.sh</URL>
    <RUN mode="755">chmod +x /usr/local/emhttp/plugins/harmraid-push/send-push.sh</RUN>
  </FILE>
  <FILE Name="/usr/local/emhttp/plugins/harmraid-push/event/notify">
    <URL>https://raw.githubusercontent.com/shanyan-wcx/Harmraid-Push/main/plugin/event/notify</URL>
    <RUN mode="755">chmod +x /usr/local/emhttp/plugins/harmraid-push/event/notify</RUN>
  </FILE>
  <FILE Name="/usr/local/emhttp/plugins/harmraid-push/scripts/configure-push">
    <URL>https://raw.githubusercontent.com/shanyan-wcx/Harmraid-Push/main/plugin/scripts/configure-push</URL>
    <RUN mode="755">chmod +x /usr/local/emhttp/plugins/harmraid-push/scripts/configure-push</RUN>
  </FILE>
  <FILE Name="/usr/local/emhttp/plugins/harmraid-push/harmraid-push.page">
    <URL>https://raw.githubusercontent.com/shanyan-wcx/Harmraid-Push/main/plugin/webGui/harmraid-push.page</URL>
  </FILE>
  <FILE Name="/usr/local/emhttp/plugins/harmraid-push/config/settings.json">
    <URL>https://raw.githubusercontent.com/shanyan-wcx/Harmraid-Push/main/plugin/config/settings.json</URL>
  </FILE>
  <INSTALL>
    <![CDATA[
      chmod +x /usr/local/emhttp/plugins/harmraid-push/send-push.sh
      chmod +x /usr/local/emhttp/plugins/harmraid-push/event/notify
      chmod +x /usr/local/emhttp/plugins/harmraid-push/scripts/configure-push

      # Register notification event hook
      if [ ! -f /boot/config/plugins/harmraid-push/push_enabled.txt ]; then
        echo "true" > /boot/config/plugins/harmraid-push/push_enabled.txt
      fi
      if [ ! -f /boot/config/plugins/harmraid-push/types.txt ]; then
        echo "alert,warning,info" > /boot/config/plugins/harmraid-push/types.txt
      fi
      if [ ! -f /boot/config/plugins/harmraid-push/settings.json ]; then
        cp /usr/local/emhttp/plugins/harmraid-push/config/settings.json /boot/config/plugins/harmraid-push/settings.json
      fi

      logger -t harmraid-push "Plugin installed v1.0.5"

      # Clean up files from v1.0.0 (installed in wrong paths)
      rm -f /usr/local/emhttp/plugins/harmraid-push/README.md
      rm -rf /usr/local/emhttp/plugins/harmraid-push/webGui
      rm -f /usr/local/emhttp/plugins/harmraid-push/register.php

      # Background poll for device registration notification (60s max)
      LOG="/var/log/harmraid-push.log"
      (
        echo "[$(date)] [poll] Background poll started" >> "$LOG"
        for i in $(seq 1 60); do
          sleep 1
          RESULT=$(curl -s http://localhost/graphql \
            -H "Content-Type: application/json" \
            -d '{"query":"{ notifications { list(filter: { type: UNREAD, offset: 0, limit: 50 }) { id subject description importance } } }"}')
          echo "[$(date)] [poll] attempt $i: $RESULT" >> "$LOG"
          ERRORS=$(echo "$RESULT" | jq -r '.errors // empty')
          [ -n "$ERRORS" ] && echo "[$(date)] [poll] GraphQL errors: $ERRORS" >> "$LOG"
          NOTIF_COUNT=$(echo "$RESULT" | jq '.data.notifications.list | length // 0')
          echo "[$(date)] [poll] notifications count: $NOTIF_COUNT" >> "$LOG"
          REG_ID=$(echo "$RESULT" | jq -r '.data.notifications.list[] | select(.subject == "HARMRAID_PUSH_REGISTER") | .id' | head -1)
          if [ -n "$REG_ID" ]; then
            echo "[$(date)] [poll] Found HARMRAID_PUSH_REGISTER id=$REG_ID" >> "$LOG"
            DESC=$(echo "$RESULT" | jq -r ".data.notifications.list[] | select(.id == \"$REG_ID\") | .description")
            echo "[$(date)] [poll] description: $DESC" >> "$LOG"
            TOKEN=$(echo "$DESC" | jq -r '.token // empty')
            DEVICE=$(echo "$DESC" | jq -r '.device_name // empty')
            echo "[$(date)] [poll] token=${TOKEN:0:16}... device=$DEVICE" >> "$LOG"
            [ -z "$TOKEN" ] && echo "[$(date)] [poll] token empty, skip" >> "$LOG" && continue
            mkdir -p /boot/config/plugins/harmraid-push
            echo "$TOKEN" >> /boot/config/plugins/harmraid-push/push_token.txt
            echo "[$(date)] [poll] token appended to push_token.txt" >> "$LOG"
            DEVICES=$(cat /boot/config/plugins/harmraid-push/devices.json 2>/dev/null || echo "[]")
            echo "$DEVICES" | jq --arg t "$TOKEN" --arg n "${DEVICE:-未知设备}" '. + [{"token": $t, "device_name": $n}]' > /boot/config/plugins/harmraid-push/devices.json
            echo "[$(date)] [poll] devices.json updated" >> "$LOG"
            ARCHIVE=$(curl -s http://localhost/graphql -H "Content-Type: application/json" \
              -d '{"query":"mutation { archiveNotification(id: \"'"$REG_ID"'\") { id } }"}')
            echo "[$(date)] [poll] archive result: $ARCHIVE" >> "$LOG"
            PUSH_RESULT=$(/usr/local/emhttp/plugins/harmraid-push/send-push.sh "推送注册成功" "设备已注册" "info" 2>&1)
            echo "[$(date)] [poll] test push result: $PUSH_RESULT" >> "$LOG"
            logger -t harmraid-push "Device registered successfully"
            echo "[$(date)] [poll] Done" >> "$LOG"
            break
          fi
        done
        echo "[$(date)] [poll] Background poll finished" >> "$LOG"
      ) &>/dev/null &
    ]]>
  </INSTALL>
  <FILE Run="/bin/bash" Method="remove">
    <INLINE>
      logger -t harmraid-push "Removing plugin..."

      # Remove all files
      rm -rf /usr/local/emhttp/plugins/harmraid-push
      rm -rf /boot/config/plugins/harmraid-push
      rm -f /var/log/plugins/harmraid-push*

      logger -t harmraid-push "Plugin removed"
    </INLINE>
  </FILE>
</PLUGIN>
