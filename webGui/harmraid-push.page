#!/bin/bash
# Harmraid Push - Unraid WebGUI 配置页面
# 通过 Unraid 的 emhttp 网页服务器加载
# 注意：Unraid 会自动包裹布局，不需要输出 DOCTYPE/html/head/body

source /usr/local/emhttp/plugins/dynamix/include/Wrappers.php

CONFIG_DIR="/boot/config/plugins/harmraid-push"
PUSH_ENABLED_FILE="${CONFIG_DIR}/push_enabled.txt"
TYPES_FILE="${CONFIG_DIR}/types.txt"
TOKEN_FILE="${CONFIG_DIR}/push_token.txt"
SETTINGS_FILE="${CONFIG_DIR}/settings.json"

# 处理表单提交
if echo "${QUERY_STRING}" | grep -q "action=save"; then
  push_enabled=$(echo "${QUERY_STRING}" | sed -n 's/.*push_enabled=//p' | cut -d'&' -f1 | sed 's/%20/ /g')
  push_types=$(echo "${QUERY_STRING}" | sed -n 's/.*push_types=//p' | cut -d'&' -f1 | sed 's/%20/ /g')

  [ -n "$push_enabled" ] && echo "$push_enabled" > "$PUSH_ENABLED_FILE"
  [ -n "$push_types" ] && echo "$push_types" > "$TYPES_FILE"

  logger -t harmraid-push "Settings saved: enabled=$push_enabled, types=$push_types"
  echo "Settings saved"
  exit 0
fi

# JSON API - 供 Harmraid App 调用
if echo "${QUERY_STRING}" | grep -q "format=json"; then
  push_enabled=$(cat "$PUSH_ENABLED_FILE" 2>/dev/null || echo "false")
  push_types=$(cat "$TYPES_FILE" 2>/dev/null || echo "alert,warning,info")
  token=$(cat "$TOKEN_FILE" 2>/dev/null || echo "")
  has_credentials="false"
  [ -n "$token" ] && has_credentials="true"
  version="1.0.0"

  cat << EOFJSON
{
  "installed": true,
  "version": "${version}",
  "pushEnabled": ${push_enabled},
  "pushTypes": "${push_types}",
  "hasCredentials": ${has_credentials},
  "configStatus": "configured"
}
EOFJSON
  exit 0
fi

# 设备注册 API - 供 Harmraid App 调用
if echo "${QUERY_STRING}" | grep -q "action=register"; then
  token=$(echo "${QUERY_STRING}" | sed -n 's/.*token=//p' | cut -d'&' -f1)
  app_id=$(echo "${QUERY_STRING}" | sed -n 's/.*app_id=//p' | cut -d'&' -f1)
  app_secret=$(echo "${QUERY_STRING}" | sed -n 's/.*app_secret=//p' | cut -d'&' -f1)

  if [ -n "$token" ]; then
    echo "$token" > "$TOKEN_FILE"
    [ -n "$app_id" ] && echo "$app_id" > "${CONFIG_DIR}/app_id.txt"
    [ -n "$app_secret" ] && echo "$app_secret" > "${CONFIG_DIR}/app_secret.txt"
    logger -t harmraid-push "Device registered: token=${token:0:16}..."
    echo '{"status":"ok"}'
  else
    echo '{"status":"error","message":"Missing token"}'
  fi
  exit 0
fi

# 读取当前配置
push_enabled=$(cat "$PUSH_ENABLED_FILE" 2>/dev/null || echo "false")
push_types=$(cat "$TYPES_FILE" 2>/dev/null || echo "alert,warning,info")
token=$(cat "$TOKEN_FILE" 2>/dev/null || echo "")
token_display="${token:0:16}..."
[ -z "$token" ] && token_display="未注册"

# 渲染配置页面（不加外层 HTML 结构，Unraid 自动布局）
echo "<h1>Harmraid 推送通知</h1>"
echo "<p>将 Unraid 通知推送到您的 Harmraid App。</p>"
echo "<hr>"

echo "<form method='GET' action='/plugins/harmraid-push/harmraid-push.page'>"
echo "<input type='hidden' name='action' value='save'>"

echo "<h3>推送状态</h3>"
echo "<label><input type='checkbox' name='push_enabled' value='true' $( [ "$push_enabled" = "true" ] && echo "checked")> 启用推送通知</label>"
echo "<br><br>"

echo "<h3>通知类型</h3>"
echo "<p>选择需要推送的通知类型：</p>"
for type_name in "alert" "warning" "info"; do
  checked=""
  echo "$push_types" | grep -q "$type_name" && checked="checked"
  label=""
  case "$type_name" in
    alert) label="错误 (Alert)" ;;
    warning) label="警告 (Warning)" ;;
    info) label="普通通知 (Info)" ;;
  esac
  echo "<label><input type='checkbox' name='push_types' value='${type_name}' ${checked}> ${label}</label><br>"
done
echo "<br>"

echo "<h3>设备状态</h3>"
echo "<p>推送令牌: ${token_display}</p>"

echo "<br><input type='submit' value='保存设置' class='button'>"
echo "</form>"
